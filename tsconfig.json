{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [
    "cli.ts",
    "engine/**/*.ts",
    "profiles/**/*.ts",
    "swarm/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
